{
	"name": "cc-second-opinion",
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"start": "bun run src/index.ts",
		"build": "bun build src/index.ts --compile --outfile dist/second-opinion",
		"prepare": "husky"
	},
