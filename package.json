		"@modelcontextprotocol/sdk": "^1.29.0",
		"zod": "^3.25.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@types/bun": "latest",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"typescript": "^5.0.0"
	}
}
